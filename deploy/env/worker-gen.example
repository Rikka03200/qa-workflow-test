# Worker-gen environment example. Keep real values out of git.
# worker-gen only needs platform DB/Fernet plus weak-model/Jira runtime inputs.

QA_WEBAPP_DATABASE_URL=postgresql+psycopg://qa_workflow:REPLACE_ME@postgres:5432/qa_workflow
QA_FERNET_KEYS=REPLACE_ME_FERNET_KEY
QA_GENERATION_WORKER_CONCURRENCY=3
QA_WEBAPP_CONCURRENCY=4
QA_QUEUE_POOL_MIN_SIZE=1
QA_QUEUE_POOL_MAX_SIZE=2
QA_QUEUE_POOL_MAX_LIFETIME=3600
QA_USE_DB_ARTIFACTS=1
QA_KB_STRICT=1
QA_JIRA_RATE_QPS=1
QA_JIRA_RATE_BURST=5
QA_JIRA_CACHE_TTL_SECONDS=900
QA_QUEUE_DEPTH_WARN=50

# Optional weak-model defaults. Per-user web settings override these for web-triggered jobs.
# CHEAP_MODEL_PROVIDER=anthropic
# CHEAP_MODEL_BASE_URL=https://example.invalid/anthropic
# CHEAP_MODEL_API_KEY=REPLACE_ME
# CHEAP_MODEL_NAME=qwen3.7-max
# CHEAP_MODEL_ENABLED=true
