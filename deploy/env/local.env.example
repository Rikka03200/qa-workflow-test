# Optional template for deploy/env/local.env. Prefer generating it with:
#   python deploy/init-local-env.py
# Keep real values out of git.

POSTGRES_DB=qa_workflow
POSTGRES_USER=qa_workflow
POSTGRES_PASSWORD=REPLACE_ME
QA_WEBAPP_DATABASE_URL=postgresql+psycopg://qa_workflow:REPLACE_ME@postgres:5432/qa_workflow
QA_WEBAPP_SECRET=REPLACE_ME_32_BYTES_OR_MORE
QA_FERNET_KEYS=REPLACE_ME_FERNET_KEY
QA_WEBAPP_SECURE_COOKIE=0
QA_WEBAPP_PORT=8800
QA_WEBAPP_CONCURRENCY=4
QA_USE_WORKER=1
QA_USE_DB_ARTIFACTS=1
QA_KB_STRICT=1
QA_DB_POOL_SIZE=5
QA_DB_MAX_OVERFLOW=5
QA_DB_POOL_RECYCLE=3600
QA_QUEUE_POOL_MIN_SIZE=1
QA_QUEUE_POOL_MAX_SIZE=2
QA_QUEUE_POOL_MAX_LIFETIME=3600
QA_GENERATION_WORKER_CONCURRENCY=3
QA_REVIEW_WORKER_CONCURRENCY=6
QA_JIRA_RATE_QPS=1
QA_JIRA_RATE_BURST=5
QA_JIRA_CACHE_TTL_SECONDS=900
QA_QUEUE_DEPTH_WARN=50
